# SoMe-assistenten brukar bring-your-own-key (BYOK): kvar brukar limer inn sin
# eigen Gemini-nøkkel i appen (lagra i nettlesaren, send via x-api-key-header).
# Det finst INGEN server-side GEMINI_API_KEY, så .env er heilt valfri.

# Port for serveren (standard: 3000)
PORT=3000

# Miljø (development eller production)
NODE_ENV=development

# Maks tal på API-førespurnader per minutt per IP (standard: 30)
RATE_LIMIT_MAX=30
