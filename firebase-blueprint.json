{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's unique ID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" },
        "createdAt": { "type": "timestamp", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A brand profile for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID of the user who owns this brand" },
        "name": { "type": "string", "description": "Name of the brand" },
        "industry": { "type": "string", "description": "Industry of the brand" },
        "language": { "type": "string", "description": "Primary language" },
        "tone_of_voice": { "type": "string", "description": "Tone of voice" },
        "target_audience": { "type": "string", "description": "Target audience" },
        "website_url": { "type": "string", "description": "Website URL" },
        "createdAt": { "type": "timestamp", "description": "When the brand was created" },
        "updatedAt": { "type": "timestamp", "description": "When the brand was last updated" }
      },
      "required": ["uid", "name", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "A website brand analysis generated by AI",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID of the user who created this analysis" },
        "url": { "type": "string", "description": "The URL analyzed" },
        "company_summary": { "type": "string" },
        "products_services": { "type": "array", "items": { "type": "string" } },
        "target_audience": { "type": "array", "items": { "type": "string" } },
        "tone_of_voice": { "type": "string" },
        "usp": { "type": "array", "items": { "type": "string" } },
        "content_pillars": { "type": "array", "items": { "type": "string" } },
        "cta_suggestions": { "type": "array", "items": { "type": "string" } },
        "brand_risks_or_gaps": { "type": "array", "items": { "type": "string" } },
        "golden_nuggets": { "type": "array", "items": { "type": "string" } },
        "confidence_notes": { "type": "string" },
        "competitor_analysis": {
          "type": "object",
          "properties": {
            "own_summary": { "type": "string" },
            "competitors": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name_or_url": { "type": "string" },
                  "summary": { "type": "string" },
                  "positioning": { "type": "string" },
                  "main_topics": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "similarities": { "type": "array", "items": { "type": "string" } },
            "differences": { "type": "array", "items": { "type": "string" } },
            "content_gaps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "theme": { "type": "string" },
                  "description": { "type": "string" },
                  "why_it_matters": { "type": "string" },
                  "suggested_formats": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "createdAt": { "type": "timestamp", "description": "When the analysis was created" }
      },
      "required": ["uid", "company_summary", "createdAt"]
    },
    "Plan": {
      "title": "Plan",
      "description": "A 30-day content plan generated by AI",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID of the user who created this plan" },
        "analysisId": { "type": "string", "description": "ID of the analysis this plan is based on" },
        "plan_summary": { "type": "string" },
        "posts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "number" },
              "channel": { "type": "string" },
              "theme": { "type": "string" },
              "post_goal": { "type": "string" },
              "format": { "type": "string" },
              "angle": { "type": "string" },
              "cta": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "timestamp", "description": "When the plan was created" }
      },
      "required": ["uid", "plan_summary", "posts", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post generated by AI",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID of the user who created this post" },
        "planId": { "type": "string", "description": "ID of the plan this post belongs to (optional)" },
        "channel": { "type": "string" },
        "hook": { "type": "string" },
        "main_caption": { "type": "string" },
        "short_version": { "type": "string" },
        "hashtag_suggestions": { "type": "array", "items": { "type": "string" } },
        "image_prompt": { "type": "string" },
        "alternative_variant": { "type": "string" },
        "createdAt": { "type": "timestamp", "description": "When the post was created" }
      },
      "required": ["uid", "channel", "hook", "main_caption", "createdAt"]
    },
    "VoiceProfile": {
      "title": "VoiceProfile",
      "description": "Brand Voice DNA profile",
      "type": "object",
      "properties": {
        "brandId": { "type": "string", "description": "ID of the brand this profile belongs to" },
        "summary": { "type": "string", "description": "Summary of the brand voice" },
        "dos": { "type": "array", "items": { "type": "string" }, "description": "What to do" },
        "donts": { "type": "array", "items": { "type": "string" }, "description": "What not to do" },
        "referenceTexts": { "type": "array", "items": { "type": "string" }, "description": "Reference texts" },
        "createdAt": { "type": "number", "description": "When the profile was created" },
        "updatedAt": { "type": "number", "description": "When the profile was last updated" }
      },
      "required": ["brandId", "summary", "dos", "donts", "referenceTexts", "createdAt", "updatedAt"]
    },
    "Article": {
      "title": "Article",
      "description": "An article generated with outline and content",
      "type": "object",
      "properties": {
        "brandId": { "type": "string", "description": "ID of the brand this article belongs to" },
        "topic": { "type": "string", "description": "The topic of the article" },
        "outline": { "type": "string", "description": "The outline of the article" },
        "content": { "type": "string", "description": "The content of the article" },
        "status": { "type": "string", "enum": ["draft", "ready", "published"], "description": "Status of the article" },
        "createdAt": { "type": "number", "description": "When the article was created" },
        "updatedAt": { "type": "number", "description": "When the article was last updated" }
      },
      "required": ["brandId", "topic", "outline", "content", "status", "createdAt", "updatedAt"]
    },
    "AILog": {
      "title": "AILog",
      "description": "Log of an AI interaction for observability",
      "type": "object",
      "properties": {
        "flow": { "type": "string" },
        "version": { "type": "string" },
        "model": { "type": "string" },
        "input": { "type": "object" },
        "output": { "type": "object" },
        "latency": { "type": "number" },
        "groundingUsed": { "type": "boolean" },
        "status": { "type": "string" },
        "timestamp": { "type": "timestamp" }
      },
      "required": ["flow", "version", "model", "timestamp"]
    },
    "TestCase": {
      "title": "TestCase",
      "description": "A test case for AI evaluation",
      "type": "object",
      "properties": {
        "flow": { "type": "string" },
        "input": { "type": "object" },
        "description": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["flow", "input", "createdAt"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Evaluation of an AI output",
      "type": "object",
      "properties": {
        "testCaseId": { "type": "string" },
        "logId": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "tone": { "type": "number" },
            "concreteness": { "type": "number" },
            "factRisk": { "type": "number" },
            "editEffort": { "type": "number" }
          }
        },
        "comments": { "type": "string" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "timestamp": { "type": "timestamp" }
      },
      "required": ["testCaseId", "logId", "scores", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/brands/{brandId}": {
      "schema": { "$ref": "#/entities/Brand" },
      "description": "Brand profiles"
    },
    "/users/{userId}/brands/{brandId}/analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/Analysis" },
      "description": "Website brand analyses"
    },
    "/users/{userId}/brands/{brandId}/plans/{planId}": {
      "schema": { "$ref": "#/entities/Plan" },
      "description": "Monthly content plans"
    },
    "/users/{userId}/brands/{brandId}/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Generated social media posts"
    },
    "/voiceProfiles/{brandId}": {
      "schema": { "$ref": "#/entities/VoiceProfile" },
      "description": "Brand Voice DNA profiles"
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Generated articles"
    },
    "/aiLogs/{logId}": {
      "schema": { "$ref": "#/entities/AILog" },
      "description": "AI interaction logs"
    },
    "/testCases/{testCaseId}": {
      "schema": { "$ref": "#/entities/TestCase" },
      "description": "AI evaluation test cases"
    },
    "/evaluations/{evaluationId}": {
      "schema": { "$ref": "#/entities/Evaluation" },
      "description": "AI output evaluations"
    }
  }
}
